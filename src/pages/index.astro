---
import HomeLayout from "../layouts/HomeLayout.astro";
import Button from "../components/CtaLink.astro";
import ScrollDivider from "../components/ScrollDivider.astro";

import videoPoster from "../images/portfolio-sequence-poster.png";
import videoMp4 from "../images/portfolio-sequence.h264.mp4";
import videoWebm from "../images/portfolio-sequence.av1.webm";

const pageTitle = "Home";
---

<script>
  import { gsap } from "gsap";
  import { initGlobalLenis } from "../lib/initGlobalLenis";

  type CleanupFn = () => void;

  declare global {
    interface Window {
      __mwHeroWindowMaskCleanup?: CleanupFn;
      __mwHeroWindowMaskListenersBound?: boolean;
    }
  }

  const siteTypes = [
    "ecommerce sites",
    "web applications",
    "dashboards & portals",
    "marketing sites",
    "SaaS platforms",
  ];

  const toLetterSpans = (el, text) => {
    el.textContent = "";
    const fragment = document.createDocumentFragment();

    text.split("").forEach((char) => {
      const letterEl = document.createElement("span");
      letterEl.className = "site-type-letter";
      letterEl.style.display = "inline-block";
      letterEl.textContent = char === " " ? "\u00A0" : char;
      fragment.appendChild(letterEl);
    });

    el.appendChild(fragment);
    return Array.from(el.querySelectorAll(".site-type-letter"));
  };

  const animateSiteType = () => {
    const siteTypeEl = document.querySelector("#siteType");
    const siteTypeStopEl = document.querySelector("#siteTypeStop");
    const gsapRef = gsap;

    if (!siteTypeEl || !gsapRef) {
      return;
    }

    let currentIndex = 0;
    let isAnimating = false;

    toLetterSpans(siteTypeEl, siteTypeEl.textContent.trim());

    const runCycle = () => {
      if (isAnimating) {
        return;
      }

      isAnimating = true;

      const currentLetters = Array.from(
        siteTypeEl.querySelectorAll(".site-type-letter")
      );

      gsapRef.to(currentLetters, {
        opacity: 0,
        duration: 0.28,
        ease: "power2.in",
        stagger: 0.03,
        onComplete: () => {
          siteTypeEl.textContent = "";

          if (siteTypeStopEl) {
            gsapRef.fromTo(
              siteTypeStopEl,
              { opacity: 0.5, color: "#d65e5e" },
              {
                opacity: 1,
                color: "#fffddb",
                duration: 1.5,
                ease: "power2.out",
              }
            );
          }

          const nextText = siteTypes[currentIndex];
          currentIndex = (currentIndex + 1) % siteTypes.length;
          const nextLetters = toLetterSpans(siteTypeEl, nextText);

          gsapRef.set(nextLetters, { opacity: 0.2, color: "#d65e5e" });
          gsapRef.to(nextLetters, {
            opacity: 1,
            color: "#fffddb",
            duration: 0.32,
            ease: "power2.out",
            stagger: 0.03,
            delay: 0.12,
            onComplete: () => {
              isAnimating = false;
              gsapRef.delayedCall(1, runCycle);
            },
          });
        },
      });
    };

    gsapRef.delayedCall(1, runCycle);
  };

  const cleanupHeroWindowMask = () => {
    window.__mwHeroWindowMaskCleanup?.();
    window.__mwHeroWindowMaskCleanup = undefined;
    document.documentElement.style.setProperty("--hero-window-progress", "0");
  };

  const initHeroWindowMask = () => {
    cleanupHeroWindowMask();

    const maskEl = document.querySelector(".hero-window-mask");
    if (!maskEl) {
      return;
    }

    const maxDistance = Math.max(window.innerHeight * 0.55, 280);

    const updateMask = () => {
      const progress = Math.min(window.scrollY / maxDistance, 1);
      document.documentElement.style.setProperty(
        "--hero-window-progress",
        progress.toFixed(4)
      );
    };

    updateMask();

    const lenis = initGlobalLenis();
    let cleanup: CleanupFn = () => {};

    if (lenis) {
      lenis.on("scroll", updateMask);
      cleanup = () => {
        lenis.off("scroll", updateMask);
      };
    } else {
      window.addEventListener("scroll", updateMask, { passive: true });
      cleanup = () => {
        window.removeEventListener("scroll", updateMask);
      };
    }

    window.addEventListener("resize", updateMask, { passive: true });

    window.__mwHeroWindowMaskCleanup = () => {
      window.removeEventListener("resize", updateMask);
      cleanup();
    };
  };

  const initHomePageAnimations = () => {
    animateSiteType();
    initHeroWindowMask();
  };

  if (!window.__mwHeroWindowMaskListenersBound) {
    document.addEventListener("astro:before-swap", cleanupHeroWindowMask);
    document.addEventListener("astro:page-load", initHeroWindowMask);
    window.__mwHeroWindowMaskListenersBound = true;
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHomePageAnimations, {
      once: true,
    });
  } else {
    initHomePageAnimations();
  }
</script>

<HomeLayout pageTitle={pageTitle}>
  <div class="hero-window-mask" aria-hidden="true"></div>
  <section class="work-section">
    <h2>Helping your sites shine</h2>
    <div class="work-sequence-container">
      <div class="col-1">
        <h3>
          Web design and development studio adding that special human touch to
          your <span id="siteType" class="whitespace-nowrap">sites</span><span
            id="siteTypeStop">.</span
          >
        </h3>
        <div class="cta">
          <Button href="/work/swiftaid" text="View Work" />
          <p>Explore a blend of creative web and application design.</p>
        </div>
      </div>
      <div class="col-2">
        <video
          autoplay="true"
          loop
          width="615"
          height="430"
          class="work-image"
          poster={videoPoster.src}
        >
          <source type="video/mp4" src={videoMp4} />
          <source type="video/webm" src={videoWebm} />
          <p>Download and watch <a href={videoMp4}>video</a></p>
        </video>
      </div>
    </div>
  </section>

  <ScrollDivider />
</HomeLayout>
