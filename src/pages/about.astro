---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About";
---

<BaseLayout pageTitle={pageTitle} sidebar={true}>
  <h2 class="text-balance text-2xl md:text-3xl">
    Senior Frontend Engineer based in the UK
  </h2>

  <p class="text-sm md:text-base leading-normal">
    Experienced Senior Frontend Engineer, based in the UK, specialising in
    TypeScript, React & React Native, Vue, Node, and Deno. I also have backend
    experience with C#, Ruby, Node, and PHP/Laravel.
  </p>

  <p class="text-sm md:text-base leading-normal"></p>

  <p class="text-sm md:text-base leading-normal">
    Over my career, I've delivered high-impact solutions for world-class clients
    including Toyota Formula One, WWF, Playground Games, Porsche, Philips, GAP,
    and HMRC.
  </p>

  <p class="text-sm md:text-base leading-normal">
    I am interested in music, art, animation, tech and design and I'm always
    excited to discover new things.
  </p>

  <p class="text-sm md:text-base leading-normal">
    I  hope you find something of interest here.
  </p>
</BaseLayout>
