<a href="#main" class="avatar">
  <div role="heading" aria-level="1" class="avatar__heading">
    <div class="avatar__heading--name">M<span>ichael</span> Watts</div>
    <div class="avatar__heading--title">Web Developer</div>
  </div>
</a>

<script>
  const avatarTitle = document.querySelector(".avatar__heading--title");
  const contrastAttr = "data-avatar-title-contrast";
  const darkExitOffsetPx = 56;

  const updateAvatarTitleColor = () => {
    if (!avatarTitle) return;
    if (window.innerWidth < 1290) {
      avatarTitle.classList.remove("avatar__heading--title--on-dark");
      return;
    }

    const rect = avatarTitle.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;
    const stackedElements =
      "elementsFromPoint" in document
        ? document.elementsFromPoint(x, y)
        : [document.elementFromPoint(x, y)].filter(Boolean);

    const foregroundElement = stackedElements.find((element) => {
      if (!element) return false;
      if (element === avatarTitle || avatarTitle.contains(element)) return false;
      if (
        element.closest?.(
          ".avatar, .mainnav, .blur-bg, .mainnav__content, .mainnav .container"
        )
      ) {
        return false;
      }
      return true;
    });

    const contrastRoot = foregroundElement?.closest?.(`[${contrastAttr}]`);
    const contrastMode = contrastRoot?.getAttribute?.(contrastAttr);
    const navBottom =
      document.querySelector(".mainnav")?.getBoundingClientRect().bottom ?? 0;
    const shouldExitDark =
      contrastMode === "dark" &&
      contrastRoot.getBoundingClientRect().bottom <= navBottom + darkExitOffsetPx;

    avatarTitle.classList.toggle(
      "avatar__heading--title--on-dark",
      contrastMode === "dark" && !shouldExitDark
    );
  };

  let rafId = 0;
  const queueAvatarTitleColorUpdate = () => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      rafId = 0;
      updateAvatarTitleColor();
    });
  };

  queueAvatarTitleColorUpdate();
  window.addEventListener("load", queueAvatarTitleColorUpdate);
  window.addEventListener("resize", queueAvatarTitleColorUpdate);
  window.addEventListener("scroll", queueAvatarTitleColorUpdate, {
    passive: true,
  });
</script>

<style>
  .avatar {
    --heading-display: none;
    --title-display: none;
    --size: 48px;
  }

  @media screen and (min-width: 800px) {
    .avatar {
      --heading-display: inline;
    }
  }

  @media screen and (min-width: 1290px) {
    .avatar {
      --title-display: block;
    }
  }

  .avatar {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
    justify-content: start;
    margin: 0;
    z-index: 999;
  }

  .avatar__heading {
    color: var(--color-onPrimary);
    gap: var(--space-2xs);
    display: flex;
    font-family: var(--header-font);
    font-size: var(--step-2);
    font-weight: bold;
    transform-origin: left center;
    overflow: hidden;
  }

  .avatar__heading--name {
    isolation: isolate;
    z-index: 2;
  }

  .avatar__heading--name > span {
    display: var(--heading-display);
  }

  .avatar__heading--title {
    display: var(--title-display);
    color: var(--color-emphasis);
    isolation: auto;
    z-index: 1;
    overflow: hidden;
    transition: color 180ms ease-out;
  }

  .avatar__heading--title.avatar__heading--title--on-dark {
    color: var(--color-primary);
  }
</style>
