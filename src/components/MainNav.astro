---
import MainNavLink from "./MainNavLink.astro";
import ToggleTheme from "./ToggleTheme.svelte";

const { classList } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<nav
  class:list={["flex justify-between items-center", classList]}
  role="banner"
>
  <ul role="navigation" class="flex gap-4 list-none m-0 p-0">
    <li
      class:list={["font-bold mx-0 px-0", currentPath === "" ? "active" : null]}
    >
      <MainNavLink href="/" isActive={currentPath === ""}>Home</MainNavLink>
    </li>
    <li
      class:list={[
        "font-bold mx-0 px-0",
        currentPath === "about" ? "active" : null,
      ]}
    >
      <MainNavLink href="/about" isActive={currentPath === "about"}>
        About
      </MainNavLink>
    </li>
  </ul>

  <div>
    <ToggleTheme client:only="svelte" />
  </div>
</nav>
