<script>
  // On light or dark
  const logo = document.querySelector(".logo > svg");
  const contrastAttr = "data-logo-contrast";
  const darkExitOffsetPx = 56;

  const updateLogoColor = () => {
    if (!logo) return;
    if (window.innerWidth < 1290) {
      logo.classList.remove("logo--on-dark");
      return;
    }

    const rect = logo.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;
    const stackedElements =
      "elementsFromPoint" in document
        ? document.elementsFromPoint(x, y)
        : [document.elementFromPoint(x, y)].filter(Boolean);

    const foregroundElement = stackedElements.find((element) => {
      if (!element) return false;
      if (element === logo || logo.contains(element)) return false;
      if (
        element.closest?.(
          ".avatar, .mainnav, .blur-bg, .mainnav__content, .mainnav .container"
        )
      ) {
        return false;
      }
      return true;
    });

    const contrastRoot = foregroundElement?.closest?.(`[${contrastAttr}]`);
    const contrastMode = contrastRoot?.getAttribute?.(contrastAttr);
    const navBottom =
      document.querySelector(".mainnav")?.getBoundingClientRect().bottom ?? 0;
    const shouldExitDark =
      contrastMode === "dark" &&
      contrastRoot.getBoundingClientRect().bottom <=
        navBottom + darkExitOffsetPx;

    logo.classList.toggle(
      "logo--on-dark",
      contrastMode === "dark" && !shouldExitDark
    );
  };

  let rafId = 0;
  const queueLogoColorUpdate = () => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      rafId = 0;
      updateLogoColor();
    });
  };

  queueLogoColorUpdate();
  window.addEventListener("load", queueLogoColorUpdate);
  window.addEventListener("resize", queueLogoColorUpdate);
  window.addEventListener("scroll", queueLogoColorUpdate, {
    passive: true,
  });
</script>

<style>
  svg {
    transition: fill 200ms linear;
  }
  .logo--on-dark {
    fill: var(--color-primary);
  }
</style>
