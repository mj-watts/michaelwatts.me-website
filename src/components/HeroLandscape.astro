---
import clouds from "../images/background/clouds.webp";
import distantMountains from "../images/background/distant-mountains.webp";
import mountainsLeft from "../images/background/mountains-l.webp";
import mountainsRight from "../images/background/mountains-r.webp";
import foregroundLeft from "../images/background/fg-l.webp";
import foregroundRight from "../images/background/fg-r.webp";
---

<section class="hero-section">
  <div class="clouds" data-parallax-speed="0.35">
    <img src={clouds.src} />
  </div>

  <div class="distant-mountains" data-parallax-speed="0.25">
    <img src={distantMountains.src} />
  </div>

  <div class="mid-mountains" data-parallax-speed="0.2">
    <div class="mid-mountains-right">
      <img src={mountainsRight.src} class="max-w-1000" />
    </div>
    <div class="mid-mountains-left">
      <img src={mountainsLeft.src} class="max-w-1000" />
    </div>
  </div>

  <div class="near-mountains" data-parallax-speed="0.1">
    <div class="near-mountains-right hero-fg-1">
      <img src={foregroundRight.src} class="max-w-1500" />
    </div>

    <div class="near-mountains-left">
      <img src={foregroundLeft.src} class="max-w-1500" />
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { initGlobalLenis } from "../lib/initGlobalLenis";

  const initHeroParallax = () => {
    const hero = document.querySelector(".hero-section");
    if (!hero) return;

    const layers = Array.from(
      hero.querySelectorAll(
        ".clouds, .distant-mountains, .mid-mountains, .near-mountains"
      )
    );

    if (!layers.length) return;

    const layerSetters = layers.map((layer) => ({
      speed: Number(layer.getAttribute("data-parallax-speed") ?? "0"),
      setY: gsap.quickSetter(layer, "y", "px"),
    }));

    const updateParallax = () => {
      const heroTop = hero.getBoundingClientRect().top + window.scrollY;
      const offset = window.scrollY - heroTop;

      layerSetters.forEach(({ speed, setY }) => {
        setY(offset * speed);
      });
    };

    updateParallax();

    const lenis = initGlobalLenis();
    if (lenis) {
      lenis.on("scroll", updateParallax);
      window.addEventListener(
        "beforeunload",
        () => {
          lenis.off("scroll", updateParallax);
        },
        { once: true }
      );
      return;
    }

    window.addEventListener("scroll", updateParallax, { passive: true });
    window.addEventListener(
      "beforeunload",
      () => {
        window.removeEventListener("scroll", updateParallax);
      },
      { once: true }
    );
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroParallax, {
      once: true,
    });
  } else {
    initHeroParallax();
  }
</script>
