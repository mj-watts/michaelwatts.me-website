---
import WorkLayout from "../layouts/WorkLayout.astro";
import ArrowRight from "../components/icons/ArrowRight.astro";
import Mouse from "../components/icons/Mouse.astro";

const { frontmatter } = Astro.props;
const { title, description, summary, nextTitle, nextDescription, nextLink } =
  frontmatter;
---

<WorkLayout
  pageTitle={title}
  pageDescription={description}
  nextTitle={nextTitle}
  nextDescription={nextDescription}
  nextLink={nextLink}
>
  <div class="row">
    <div class="col-1">
      <h1 class="heading">{title}</h1>
      {summary.map((para) => <p class="body">{para}</p>)}
    </div>

    <div class="col-2">
      <ul>
        {
          frontmatter.tags.map((tag: { tag: string }) => (
            <li>
              <span class="tag-item tag-item--base">
                <ArrowRight /> {tag}
              </span>
              <span class="tag-item tag-item--reveal" aria-hidden="true">
                <ArrowRight /> {tag}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="col-3">
      <div class="col-3-scroll">
        <slot />
      </div>
      <div class="scroll-cta">
        <div class="text">Scroll for more...</div>
        <div><Mouse /></div>
      </div>
    </div>
  </div>
</WorkLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { initGlobalLenis } from "../lib/initGlobalLenis";

  gsap.registerPlugin(ScrollTrigger);
  type CleanupFn = () => void;

  declare global {
    interface Window {
      __mwWorkLayoutNewCleanup?: CleanupFn;
      __mwWorkLayoutNewListenersBound?: boolean;
    }
  }

  const cleanupCurrentPage = () => {
    window.__mwWorkLayoutNewCleanup?.();
    window.__mwWorkLayoutNewCleanup = undefined;
  };

  const setupCurrentPage = () => {
    cleanupCurrentPage();
    initGlobalLenis();

    const col3 = document.querySelector(".col-3");
    const scroller = document.querySelector(".col-3-scroll");
    const scrollCta = document.querySelector(".scroll-cta");

    if (
      !(col3 instanceof HTMLElement) ||
      !(scroller instanceof HTMLElement) ||
      !(scrollCta instanceof HTMLElement)
    ) {
      return;
    }

    const cleanups: CleanupFn[] = [];
    const addCleanup = (cleanup: CleanupFn) => cleanups.push(cleanup);

    const updateScrollCta = () => {
      col3.classList.toggle("is-scrolled", scroller.scrollTop > 8);
    };
    updateScrollCta();
    scroller.addEventListener("scroll", updateScrollCta, { passive: true });
    addCleanup(() => scroller.removeEventListener("scroll", updateScrollCta));

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (!reduceMotion) {
      const content = document.querySelector(".col-3-scroll > .content");
      const work = document.querySelector(".row");
      const col1 = document.querySelector(".col-1");
      const col2 = document.querySelector(".col-2");
      const listItems = gsap.utils.toArray<HTMLElement>(".col-2 li");

      if (content && work && col1 && col2) {
        const pinTrigger = ScrollTrigger.create({
          scroller,
          trigger: content,
          start: "top top",
          endTrigger: content,
          end: "bottom bottom-=100",
        });
        addCleanup(() => pinTrigger.kill());
      }

      // Route page-level scroll intent into the internal .col-3 scroller.
      const isEditableElement = (
        target: EventTarget | null
      ): target is HTMLElement => {
        if (!(target instanceof HTMLElement)) return false;
        return Boolean(
          target.closest(
            'input, textarea, select, [contenteditable="true"], [contenteditable=""]'
          )
        );
      };

      const scrollCol3By = (deltaY: number) => {
        if (!deltaY || !scroller.isConnected) return;
        scroller.scrollBy({ top: deltaY, behavior: "auto" });
      };

      const isDesktopLayout = () =>
        window.matchMedia("(min-width: 1024px)").matches;

      const onWindowWheel = (event: WheelEvent) => {
        if (!isDesktopLayout()) return;
        if (isEditableElement(event.target)) return;
        event.preventDefault();
        scrollCol3By(event.deltaY);
      };

      let touchStartY = 0;
      const onTouchStart = (event: TouchEvent) => {
        if (isEditableElement(event.target)) return;
        if (event.touches.length > 0) {
          touchStartY = event.touches[0].clientY;
        }
      };

      const onTouchMove = (event: TouchEvent) => {
        if (!isDesktopLayout()) return;
        if (isEditableElement(event.target)) return;
        if (event.touches.length === 0) return;
        const currentY = event.touches[0].clientY;
        const deltaY = touchStartY - currentY;
        touchStartY = currentY;
        event.preventDefault();
        scrollCol3By(deltaY);
      };

      const onKeyDown = (event: KeyboardEvent) => {
        if (!isDesktopLayout()) return;
        if (isEditableElement(event.target)) return;

        let deltaY = 0;
        const pageAmount = scroller.clientHeight * 0.9;
        switch (event.key) {
          case "ArrowDown":
            deltaY = 60;
            break;
          case "ArrowUp":
            deltaY = -60;
            break;
          case "PageDown":
            deltaY = pageAmount;
            break;
          case "PageUp":
            deltaY = -pageAmount;
            break;
          case "Home":
            deltaY = -scroller.scrollTop;
            break;
          case "End":
            deltaY =
              scroller.scrollHeight -
              scroller.clientHeight -
              scroller.scrollTop;
            break;
          case " ":
            deltaY = event.shiftKey ? -pageAmount : pageAmount;
            break;
          default:
            return;
        }

        event.preventDefault();
        scrollCol3By(deltaY);
      };

      window.addEventListener("wheel", onWindowWheel, { passive: false });
      window.addEventListener("touchstart", onTouchStart, { passive: true });
      window.addEventListener("touchmove", onTouchMove, { passive: false });
      window.addEventListener("keydown", onKeyDown);
      addCleanup(() => {
        window.removeEventListener("wheel", onWindowWheel);
        window.removeEventListener("touchstart", onTouchStart);
        window.removeEventListener("touchmove", onTouchMove);
        window.removeEventListener("keydown", onKeyDown);
      });

      if (content && listItems.length > 0) {
        gsap.set(listItems, { "--reveal-progress": 0 });
        listItems.forEach((item) => {
          item.dataset.revealState = "hidden";
        });

        const revealTween = gsap.to(listItems, {
          "--reveal-progress": 1,
          ease: "none",
          stagger: {
            each: 0.5,
          },
          scrollTrigger: {
            scroller,
            trigger: content,
            endTrigger: content,
            start: "top top",
            end: "bottom bottom",
            scrub: 2.5,
          },
          onUpdate() {
            listItems.forEach((item) => {
              const revealProgress = Number(
                getComputedStyle(item).getPropertyValue("--reveal-progress")
              );

              if (revealProgress <= 0.75) {
                item.dataset.revealState = "hidden";
                return;
              }

              if (
                revealProgress < 0.98 ||
                item.dataset.revealState === "revealed"
              ) {
                return;
              }

              const revealIcon = item.querySelector<HTMLElement>(
                ".tag-item--reveal .icon-container"
              );
              if (!revealIcon) return;

              revealIcon.classList.remove("tag-icon--animate");
              void revealIcon.offsetWidth;
              revealIcon.classList.add("tag-icon--animate");
              item.dataset.revealState = "revealed";
            });
          },
        });

        addCleanup(() => {
          revealTween.scrollTrigger?.kill();
          revealTween.kill();
        });

        listItems.forEach((item) => {
          const revealIcon = item.querySelector<HTMLElement>(
            ".tag-item--reveal .icon-container"
          );
          if (!revealIcon) return;

          const onAnimationEnd = () => {
            revealIcon.classList.remove("tag-icon--animate");
          };

          revealIcon.addEventListener("animationend", onAnimationEnd);
          addCleanup(() => {
            revealIcon.removeEventListener("animationend", onAnimationEnd);
          });
        });
      }

      requestAnimationFrame(() => ScrollTrigger.refresh());
    }

    window.__mwWorkLayoutNewCleanup = () => {
      cleanups.forEach((cleanup) => cleanup());
    };
  };

  if (!window.__mwWorkLayoutNewListenersBound) {
    document.addEventListener("astro:before-swap", cleanupCurrentPage);
    document.addEventListener("astro:page-load", setupCurrentPage);
    window.__mwWorkLayoutNewListenersBound = true;
  }

  setupCurrentPage();
</script>
