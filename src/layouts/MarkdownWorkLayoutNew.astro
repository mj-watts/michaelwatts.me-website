---
import WorkLayout from "../layouts/WorkLayout.astro";
import ArrowRight from "../components/icons/ArrowRight.astro";
import Tags from "../components/Tags.tsx";
import { recommendedWork } from "../store";

const { frontmatter } = Astro.props;
const { title, description, summary } = frontmatter;

const rw = recommendedWork.get();

const workList = frontmatter.recommendedWork.map((key: string) => ({
  bgcolor: rw[key].bgcolor,
  image: rw[key].image,
  title: rw[key].title,
  description: rw[key].description,
  link: rw[key].link,
}));
---

<WorkLayout pageTitle={title} pageDescription={description}>
  <div class="work">
    <div class="col-1">
      <h1>{title}</h1>
      <p>{summary}</p>
    </div>

    <div class="col-2">
      <ul>
        {
          frontmatter.tags.map((tag: { tag: string }) => (
            <li>
              <ArrowRight /> {tag}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="col-3">
      <slot />
    </div>
  </div>
</WorkLayout>

<style>
  .work {
    --grid-template-columns: 1fr;
    --gap: var(--space-2xl);
  }

  @media screen and (min-width: 1000px) {
    .work {
      --grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1550px) and (min-height: 1200px) {
    .work {
      --grid-template-columns: 0.5fr 0.5fr 1.5fr;
    }
  }

  .work {
    display: grid;
    grid-template-columns: var(--grid-template-columns);
    gap: var(--gap);
    margin-top: var(--space-2xl);
  }

  .col-1 {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);

    h1 {
      font-size: var(--step--1);
      text-transform: uppercase;
      letter-spacing: var(--space-3xs);
      opacity: 0.75;
    }

    p {
      font-size: var(--step-0);
      color: var(--color-emphasis);
      line-height: var(--space-m);
    }
  }

  .col-2 {
    ul {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: start;
      gap: var(--space-xs);
    }

    li {
      display: flex;
      gap: var(--space-2xs);
      align-items: center;
      font-size: var(--step--1);
      font-variation-settings: var(--font-semi-bold);
      opacity: 0.5;
    }
  }
  .col-3 {
  }
</style>
