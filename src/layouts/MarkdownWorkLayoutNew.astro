---
import WorkLayout from "../layouts/WorkLayout.astro";
import ArrowRight from "../components/icons/ArrowRight.astro";
import Tags from "../components/Tags.tsx";
import { recommendedWork } from "../store";

const { frontmatter } = Astro.props;
const { title, description, summary } = frontmatter;

const rw = recommendedWork.get();

const workList = frontmatter.recommendedWork.map((key: string) => ({
  bgcolor: rw[key].bgcolor,
  image: rw[key].image,
  title: rw[key].title,
  description: rw[key].description,
  link: rw[key].link,
}));
---

<WorkLayout pageTitle={title} pageDescription={description}>
  <div class="work">
    <div class="col-1">
      <h1>{title}</h1>
      <p>{summary}</p>
    </div>

    <div class="col-2">
      <ul>
        {
          frontmatter.tags.map((tag: { tag: string }) => (
            <li>
              <ArrowRight /> {tag}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="col-3">
      <slot />
    </div>
  </div>
</WorkLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { initGlobalLenis } from "../lib/initGlobalLenis";

  gsap.registerPlugin(ScrollTrigger);
  initGlobalLenis();

  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (!reduceMotion) {
    const work = document.querySelector(".work");
    const col1 = document.querySelector(".col-1");
    const col2 = document.querySelector(".col-2");
    const listItems = gsap.utils.toArray(".col-2 li");

    if (work && col1 && col2) {
      ScrollTrigger.create({
        trigger: work,
        start: "top top+=130",
        endTrigger: ".col-3",
        end: "bottom bottom-=100",
        pin: col1,
        pinSpacing: false,
      });

      ScrollTrigger.create({
        trigger: work,
        start: "top top+=130",
        endTrigger: ".col-3",
        end: "bottom bottom-=100",
        pin: col2,
        pinSpacing: false,
      });
    }

    if (work && listItems.length > 0) {
      gsap.set(listItems, { opacity: 0.3 });

      gsap.to(listItems, {
        opacity: 1,
        ease: "none",
        stagger: {
          each: 0.25,
        },
        scrollTrigger: {
          trigger: work,
          start: "top top+=130",
          end: "bottom bottom-=100",
          scrub: true,
        },
      });
    }
  }
</script>

<style>
  .work {
    --grid-template-columns: 1fr;
    --gap: var(--space-2xl);
  }

  @media screen and (min-width: 1000px) {
    .work {
      --grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1550px) and (min-height: 1200px) {
    .work {
      --grid-template-columns: 0.5fr 0.5fr 1.5fr;
    }
  }

  .work {
    display: grid;
    grid-template-columns: var(--grid-template-columns);
    gap: var(--gap);
    margin-top: var(--space-2xl);
  }

  .col-1 {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);

    h1 {
      font-size: var(--step--1);
      text-transform: uppercase;
      letter-spacing: var(--space-3xs);
      opacity: 0.75;
    }

    p {
      font-size: var(--step-0);
      color: var(--color-emphasis);
      line-height: var(--space-m);
    }
  }

  .col-2 {
    ul {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: start;
      gap: var(--space-xs);
    }

    li {
      display: flex;
      gap: var(--space-2xs);
      align-items: center;
      font-size: var(--step--1);
      font-variation-settings: var(--font-semi-bold);
    }
  }
  .col-3 {
  }
</style>
