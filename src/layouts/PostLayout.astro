---
import MainNav from "../components/MainNav.astro";
import Sidebar from "../components/Sidebar.astro";
import MainFooter from "../components/Footer.astro";
import "../styles/styles.css";

const mainTitle = "Michael Watts, Software Engineer";
const { pageTitle, pageDescription } = Astro.props;

---
<html lang="en" class="dark border-8 border-brand-400 dark:border-brand-800">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{mainTitle} | {pageTitle}</title>
    <meta
      name="description"
      content={pageDescription}
    />
    <link rel="stylesheet" href="https://use.typekit.net/eaq6veo.css" />
    <script
      data-collect-dnt="true"
      async
      src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </head>
  <body class="md:grid md:grid-cols-4 gap-5">
    <Sidebar classList="hidden lg:block md:col-span-1" />

    <main
      id="main"
      role="main"
      class="px-5 pb-4 prose dark:prose-invert prose-xl text-pretty md:col-span-3"
    >
      <MainNav classList="mt-5 xl:mt-12 mb-3 prose dark:prose-invert prose-xl " />
      <slot />
      <MainFooter classList="mt-12 pt-6 pb-2 border-t-8 border-brand-800" />
    </main>

    <script>
      // used to be able to use web components
      await import.meta.glob("../web-components/**/*.ts", {
        eager: true,
      });
    </script>
  </body>
</html>
